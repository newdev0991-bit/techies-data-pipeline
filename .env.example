# --- Database ---
# Local dev via docker-compose (see docker-compose.yml). Render injects this in prod.
DATABASE_URL=postgres://techies:techies@localhost:5433/techies_pipeline

# --- Web service ---
PORT=4100

# Comma-separated origins allowed to call the API directly (browsers). The
# frontends call via their own server-side proxy, so this is mostly for local dev.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Auth ---
# Bearer token the NFULL/MFULL push adapters + reconciliation cron must send to
# the /internal/ingest/* endpoints. Generate a long random string.
PIPELINE_API_TOKEN=dev-ingest-token-change-me

# X-API-Key that the frontend proxies send to the public read API (/api/leads).
PUBLIC_API_KEY=dev-public-key-change-me

# --- Reconciliation cron (src/reconcile.js) ---
# Where to pull each source's CSV from, and the key each expects.
NFULL_CSV_URL=https://your-nfull-backend.onrender.com/most_recent_leads_with_hyperlinks.csv
NFULL_API_KEY=
MFULL_CSV_URL=https://your-mfull-backend.onrender.com/most_recent_leads_with_hyperlinks.csv
MFULL_API_KEY=
# The pipeline's own ingest base URL the cron POSTs the parsed rows back into.
PIPELINE_BASE_URL=http://localhost:4100

# --- Milestone 2 (validation worker) ---
# Base URL of the existing techies-validator-backend the worker calls.
TECHIES_VALIDATOR_URL=https://techies-validator-backend.onrender.com
# Only leads collected at/after this instant auto-queue for validation.
# Historical rows stay INGESTED until `npm run bulk-revalidate` is run.
PIPELINE_CUTOVER_AT=2026-07-12T00:00:00Z
# Worker tuning (optional; defaults shown)
# WORKER_POLL_MS=3000
# WORKER_MAX_ATTEMPTS=4
# WORKER_RETRY_BASE_MIN=5
# Decision thresholds (doc section 6) and freshness gate (optional)
# APPROVE_MIN=75
# REVIEW_MIN=50
# FRESHNESS_HOURS=24
