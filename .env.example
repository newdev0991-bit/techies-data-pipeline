# --- Database ---
# Local dev via docker-compose (see docker-compose.yml). Render injects this in prod.
DATABASE_URL=postgres://techies:techies@localhost:5433/techies_pipeline

# --- Web service ---
PORT=4100

# Comma-separated origins allowed to call the API directly (browsers). The
# frontends call via their own server-side proxy, so this is mostly for local dev.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Auth ---
# Bearer token the NFULL/MFULL push adapters + reconciliation cron must send to
# the /internal/ingest/* endpoints. Generate a long random string.
PIPELINE_API_TOKEN=dev-ingest-token-change-me

# X-API-Key that the frontend proxies send to the public read API (/api/leads).
PUBLIC_API_KEY=dev-public-key-change-me

# --- Direct-Google ingestion (primary; used by POST /internal/tick) ---
# The pipeline reads each source's Google Sheet directly, so it never leans on the
# memory-constrained backend CSV endpoints.
#
# PREFERRED auth: a Service Account (no token expiry). Create one, share each sheet
# with its client_email (Viewer), and paste the SA JSON (single line) below.
# Real ranges observed: NFULL "Real Time Leads (Dup Checker)!A1:O",
#                       MFULL "ReaL Time Data--!A1:Z".
NFULL_SPREADSHEET_ID=
NFULL_SHEET_RANGE=Real Time Leads (Dup Checker)!A1:O
NFULL_GOOGLE_SA_JSON=
MFULL_SPREADSHEET_ID=
# NOTE the tab name is literally "Real Time Data--!" (ends with "!"), so the range
# has a double "!!" (tab-name "!" + range separator). The reader quotes it for you.
MFULL_SHEET_RANGE=Real Time Data--!!A1:Z
MFULL_GOOGLE_SA_JSON=
# One SA shared across both (if it can read both sheets) instead of per-source:
# GOOGLE_SA_JSON=
#
# FALLBACK auth: OAuth user token JSON (client_id/client_secret/refresh_token).
# Note: refresh tokens from a "testing"-mode OAuth app expire ~weekly (invalid_grant).
# NFULL_GOOGLE_OAUTH_TOKEN_JSON=
# MFULL_GOOGLE_OAUTH_TOKEN_JSON=
# GOOGLE_OAUTH_TOKEN_JSON=

# How many validation jobs each /internal/tick processes.
VALIDATION_BATCH=10

# --- Optional: legacy reconciliation cron (src/reconcile.js), CSV-pull fallback ---
# NFULL_CSV_URL=
# NFULL_API_KEY=
# MFULL_CSV_URL=
# MFULL_API_KEY=
# PIPELINE_BASE_URL=http://localhost:4100

# --- Milestone 2 (validation worker) ---
# Base URL of the existing techies-validator-backend the worker calls.
TECHIES_VALIDATOR_URL=https://techies-validator-backend.onrender.com
# Only leads collected at/after this instant auto-queue for validation.
# Historical rows stay INGESTED until `npm run bulk-revalidate` is run.
PIPELINE_CUTOVER_AT=2026-07-12T00:00:00Z
# Worker tuning (optional; defaults shown)
# WORKER_POLL_MS=3000
# WORKER_MAX_ATTEMPTS=4
# WORKER_RETRY_BASE_MIN=5
# Decision thresholds (doc section 6) and freshness gate (optional)
# APPROVE_MIN=75
# REVIEW_MIN=50
# FRESHNESS_HOURS=24
